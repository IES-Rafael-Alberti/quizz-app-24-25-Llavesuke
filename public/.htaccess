RewriteEngine On

# Excluir archivos estáticos de la redirección a index.php
RewriteCond %{REQUEST_URI} !\.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ [NC]

# Si no es un archivo o directorio existente, redirigir a index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# Asegurar que los CSS se sirvan con el tipo MIME correcto
AddType text/css .css
